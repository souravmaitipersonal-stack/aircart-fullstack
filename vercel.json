{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL",
      "example": "https://api.aircart.com"
    },
    "NEXT_PUBLIC_PAYPAL_CLIENT_ID": {
      "description": "PayPal Client ID for payments",
      "example": "your_paypal_client_id"
    },
    "NEXT_PUBLIC_ANALYTICS_ID": {
      "description": "Analytics service ID (optional)",
      "example": "google_analytics_id"
    }
  },
  "git": {
    "deploymentEnabled": true
  },
  "projects": {
    "web": {
      "link": "aircart-fullstack",
      "settings": {
        "nodeVersion": "20.x",
        "buildCommand": "npm run build",
        "outputDirectory": ".next"
      }
    }
  },
  "functions": {
    "maxDuration": 60,
    "memory": 1024
  },
  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "https://api.aircart.com/api/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ]
}
